---
import type { Walk } from '../types/walk';

interface Props {
  walk: Walk;
}

const { walk } = Astro.props;

// Format date like "Jun 14, 2026"
const formattedDate = new Date(walk.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC' // Prevent off-by-one errors from local timezone
});
---

<article class="walk-card">
  <div class="walk-content">
    <div class="walk-header">
      <h3 class="walk-title">{walk.title}</h3>
      <span class="walk-date">{formattedDate}</span>
    </div>
    
    <div class="walk-meta">
      <span class="meta-item location">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        {walk.location}
      </span>
      {walk.speciesCount && (
        <span class="meta-item species">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"></path><path d="M18 21v-4a4 4 0 0 0-4-4H8"></path><path d="M8 13v-2a4 4 0 0 1 4-4h4"></path><path d="M12 7V3"></path><path d="M16 7V3"></path></svg>
          {walk.speciesCount} species spotted
        </span>
      )}
    </div>

    {walk.description && <p class="walk-description">{walk.description}</p>}
  </div>
</article>

<style>
  .walk-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
    height: 100%;
  }

  .walk-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .walk-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    margin-bottom: var(--space-sm);
  }

  .walk-title {
    margin-bottom: 0;
    font-size: 1.25rem;
    color: var(--color-text-primary);
  }

  .walk-date {
    font-weight: 500;
    color: var(--color-accent-terracotta);
    font-size: 0.875rem;
  }

  .walk-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .walk-description {
    color: var(--color-text-secondary);
    margin-bottom: 0;
  }

  @media (min-width: 640px) {
    .walk-header {
      flex-direction: row;
      justify-content: space-between;
      align-items: baseline;
    }
  }
</style>
