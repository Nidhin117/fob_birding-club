---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Birding Stats">
  <section class="section page-header">
    <div class="container">
      <h1>Birding Stats</h1>
      <p class="subtitle">Our club's journey in numbers.</p>
    </div>
  </section>

  <section class="section stats-content">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon">📅</div>
          <span class="stat-number">Dec 2024</span>
          <span class="stat-label">Year Founded</span>
        </div>
        <div class="stat-card">
          <div class="stat-icon">🥾</div>
          <span class="stat-number">19</span>
          <span class="stat-label">Bird Walks</span>
        </div>
        <div class="stat-card">
          <div class="stat-icon">🎓</div>
          <span class="stat-number">2</span>
          <span class="stat-label">Workshops Conducted</span>
        </div>
        <div class="stat-card">
          <div class="stat-icon">🦅</div>
          <span class="stat-number">185</span>
          <span class="stat-label">Species Spotted</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-3xl);
  }

  h1 {
    font-size: 2.5rem;
    color: var(--color-accent-primary);
    margin-bottom: var(--space-sm);
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    margin-bottom: 0;
  }

  .section {
    padding: var(--space-3xl) 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-2xl);
    text-align: center;
  }

  .stat-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-normal);
  }

  .stat-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .stat-icon {
    font-size: 3rem;
    margin-bottom: var(--space-md);
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-accent-terracotta);
    line-height: 1;
    margin-bottom: var(--space-xs);
  }

  .stat-label {
    font-weight: 500;
    color: var(--color-text-secondary);
    font-size: 1.125rem;
  }
</style>
