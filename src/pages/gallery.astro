---
import BaseLayout from '../layouts/BaseLayout.astro';
import { INSTAGRAM_URL } from '../config';
---

<BaseLayout title="Gallery">
  <section class="section page-header">
    <div class="container">
      <h1>Gallery</h1>
      <p class="subtitle">A collection of moments from our bird walks and nature explorations.</p>
    </div>
  </section>

  <section class="section gallery-content">
    <div class="container">
      <div class="empty-state">
        <p>Our photo gallery is being curated and will be updated soon. In the meantime, check out our recent sightings on Instagram!</p>
        <a href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer" class="btn">View Photos on Instagram</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-3xl);
  }

  h1 {
    font-size: 2.5rem;
    color: var(--color-accent-primary);
    margin-bottom: var(--space-sm);
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    margin-bottom: 0;
  }

  .section {
    padding: var(--space-3xl) 0;
  }

  .empty-state {
    background-color: var(--color-surface);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-3xl) var(--space-xl);
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .empty-state p {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xl);
  }
</style>
